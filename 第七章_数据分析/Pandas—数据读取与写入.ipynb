    "import pandas as pd\n",
    "\n",
    "# 读取数据\n",
    "df = pd.read_csv(\"./Data/sales.csv\",usecols=['产品名称','产品类别','单价','销售数量'])\n",
    "\n",
    "df['销售额'] = df['单价'] * df['销售数量']\n",
    "\n",
    "df.to_csv(\"./Data/sales_result.csv\",index=False)"
